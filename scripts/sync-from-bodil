#!/usr/bin/env python3
"""Synk Bodils verktøy (ikke data) inn i en privat kopi av malen.

Kopierer KUN en fast allowlist av verktøyfiler fra Bodil, pinnet til en
Bodil-tag, inn i et målrepo (typisk ditt eget <selskap>-regnskap). Lager én ren
chore:-commit i målrepoet. Rører aldri regnskapsdata.

Hvorfor en egen deny-list når allowlisten allerede er smal? Belte og bukseseler:
skulle allowlisten utvides uforsiktig senere, nekter deny-listen fortsatt å
skrive over stamdata, config med fødselsnummer, bankeksport eller bilag.

Bruk (kjøres fra en Bodil-checkout, peker på målrepoet):
    python3 scripts/sync-from-bodil --target /sti/til/mitt-regnskap
    python3 scripts/sync-from-bodil --target ../mitt-regnskap --ref v0.3.0 --dry-run

Pinningen skjer via `git archive <ref>`, så Bodils arbeidskopi røres ikke, og du
får nøyaktig den taggede versjonen.
"""

from __future__ import annotations

import argparse
import fnmatch
import subprocess
import sys
import tarfile
import tempfile
from pathlib import Path

# Det eneste som synkes. Rene verktøyfiler, ingen data.
ALLOWLIST = [
    "scripts/folio_import.py",
    ".claude/skills/folio-import/SKILL.md",
    "scripts/sync-from-bodil",   # synk seg selv, så målrepoet kan oppdatere videre
]

# Stier som ALDRI skal røres, uansett hva allowlisten måtte bli endret til.
DENY_GLOBS = [
    "selskap.yaml",
    "selskap.*.yaml",
    "*/config.yaml",
    "*/bankeksport.csv",
    "*/bilag/*",
    ".env",
]


def git(args: list[str], cwd: Path) -> str:
    res = subprocess.run(["git", *args], cwd=cwd, capture_output=True, text=True)
    if res.returncode != 0:
        sys.exit(f"git {' '.join(args)} feilet i {cwd}:\n{res.stderr.strip()}")
    return res.stdout.strip()


def er_avvist(relsti: str) -> bool:
    return any(fnmatch.fnmatch(relsti, m) for m in DENY_GLOBS)


def main() -> int:
    p = argparse.ArgumentParser(description="Synk Bodils verktøy (ikke data) til et målrepo.")
    p.add_argument("--target", required=True, help="Sti til målrepoet (din private kopi)")
    p.add_argument("--ref", help="Bodil-tag å pinne til (standard: nyeste tag)")
    p.add_argument("--bodil", default=".", help="Sti til Bodil-repoet (standard: her)")
    p.add_argument("--dry-run", action="store_true", help="Vis hva som ville skjedd, ikke skriv")
    p.add_argument("--no-commit", action="store_true", help="Kopier og stage, men ikke commit")
    args = p.parse_args()

    bodil = Path(args.bodil).resolve()
    target = Path(args.target).resolve()
    if not (target / ".git").exists():
        sys.exit(f"{target} ser ikke ut som et git-repo (mangler .git).")
    if target == bodil:
        sys.exit("Målrepoet kan ikke være Bodil selv.")

    ref = args.ref or git(["describe", "--tags", "--abbrev=0"], bodil)
    print(f"Synker fra Bodil @ {ref} -> {target}")

    # Trekk ut allowlisten ved den taggede versjonen, uten å røre arbeidskopier.
    with tempfile.TemporaryDirectory() as tmp:
        arkiv = Path(tmp) / "bodil.tar"
        with arkiv.open("wb") as fh:
            res = subprocess.run(["git", "archive", "--format=tar", ref, *ALLOWLIST],
                                 cwd=bodil, stdout=fh, stderr=subprocess.PIPE, text=False)
        if res.returncode != 0:
            sys.exit(f"git archive feilet:\n{res.stderr.decode('utf-8', 'replace').strip()}")

        with tarfile.open(arkiv) as tf:
            medlemmer = [m for m in tf.getmembers() if m.isfile()]
            for m in medlemmer:
                if er_avvist(m.name):
                    sys.exit(f"NEKTET: {m.name} matcher deny-listen. Avbryter uten å skrive.")

            print(f"\n{len(medlemmer)} fil(er) i allowlisten:")
            for m in medlemmer:
                print(f"  {m.name}")

            if args.dry_run:
                print("\n--dry-run: skrev ingenting.")
                return 0

            for m in medlemmer:
                ut = target / m.name
                ut.parent.mkdir(parents=True, exist_ok=True)
                kilde = tf.extractfile(m)
                ut.write_bytes(kilde.read())
                ut.chmod(m.mode)

    filer = [m.name for m in medlemmer]
    git(["add", "--", *filer], target)
    staged = git(["diff", "--cached", "--name-only"], target)
    if not staged:
        print("\nIngen endringer å committe (målrepoet er allerede oppdatert).")
        return 0
    print(f"\nStaget:\n  " + staged.replace("\n", "\n  "))

    if args.no_commit:
        print("\n--no-commit: hoppet over commit. Commit selv når du er klar.")
        return 0

    git(["commit", "-m", f"chore: synk folio-import fra Bodil {ref}"], target)
    print(f"\nCommittet i {target}. Push selv når du har sett over.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
